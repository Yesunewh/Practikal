  "admin": {
    "accessDeniedTitle": "መዳረሻ ተከልክሏል",
    "accessDeniedBody": "ወደ አስተዳዳሪ ፓነል መዳረሻ የለዎም።",
    "overviewTitle": "አጠቃላይ እና ሪፖርቶች",
    "overviewSubtitle": "ለድርጅትዎ የተገደቡ የስልጠና መለኪያዎች እና ገበታዎች። ዝርዝር መሳሪያዎች ከጎን አሞሌ ይጠቀሙ።",
    "roleHierarchy": {
      "title": "የስርዓት ሚናዎች (ማመሳከሪያ)",
      "intro": "በዚህ ምርት ውስጥ ከስፋት ወደ ቅርበት አብዛኛው ልምድ።",
      "defaultAccessNote": "ነባሪ የተማሪ ዳሳሽ፦ የተጸድቁ ሰራተኞች ወይም ውስጣዊ (Internal) ሂሳቦች እንደ ተመረጠ የድርጅት ሚና እስካልተመድበ ድረስ እና ወይም ሚና አንዳች ፍቃዶች ካልተሰጡ በመግቢያ እንዲሁ ሙሉ የተማሪ መብቶች (ዳሽቦርድ፣ ቻለንጆች፣ መጫወት፣ እንደገና ማመላከት፣ መስመር፣ ማሸነፎች፣ ድጋፍ) ይሰጣሉ — ልዩ የፍቃድ ሰንጠርግ እስካልተፈለገ ድረስ አይነፈገም። ከስጦት የአስተዳዳሪ አይነት ከዚያ በላይ ትችቶች ይጨመራሉ።",
      "step1": "ሱፐር አስተዳዳሪ — ሙሉ የመድረክ ቁጥጥር፣ የተከራዮች አስተዳዳር፣ እና የላቀ ማረጋገጃዎች።",
      "step2": "የድርጅት አስተዳዳሪ — ለሙሉው ድርጅት (ተከራች) ማስተናገዶች እና የስራ ፍሰቶች።",
      "step3": "የቅርንጫፍ / ክፍል አስተዳዳሪ — በደረጃ ተከታታይ ውስጥ ያለ ተዋህዮ ቅርንጫፍ ወይም ክፍል (ለምሳሌ ክልል፣ ወረዳ፣ ነጥብ)።",
      "step4": "የክፍል አስተዳዳሪ — አንድ ክፍል ይመራል፦ ዝርዝር፣ የቡድን ስራ፣ የክፍል መሳሪያዎች።",
      "step5": "ሰራተኛ — ለተማሪዎች እና ኦፕሬተሮች ነባሪ ሚና። ከላይ እንደተጠቀሰ የመተግበሪያ መስመር ዳስ ያገለግላል፤ ብጁ ድርጅተኛ ሚና እስካልመነፅ ስጋት ይጨመራል ወይም ይጠበቃል።",
      "step6": "ራስ መመዝገብ — አዲስ ተጠቃሚዎች ሙሉ መዳረሻ ከመፍቀድዎ በፊት በታላቂ ምዝገባዎች ሥር እስኪፀድቁ ድረስ ሊታዩ ይችላሉ።"
    },
